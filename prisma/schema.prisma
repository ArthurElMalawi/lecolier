generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int       @id @default(autoincrement())
  nameFr      String
  nameEn      String
  slug        String    @unique
  grammageGsm Int
  coverType   CoverType
  format      Format
  ruling      Ruling?
  pages       Int
  color       String?
  imageUrl    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reseller {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  country   String
  phone     String?
  fax       String?
  email     String?
  website   String?
  lat       Float
  lng       Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CoverType {
  POLYPRO_PIQUE
  POLYPRO
  CARTONNE
}

enum Format {
  F17x22
  F21x29_7
  F24x32
}

enum Ruling {
  SEYES
  LIGNE
  QUADRI
  BLANC
}
